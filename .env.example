# --- Serveur du dashboard ---
PORT=3000
SESSION_SECRET=change-moi-avec-une-longue-chaine-aleatoire

# --- API REST Palworld (doit rester en local, jamais forward sur la box) ---
PALWORLD_API_URL=http://127.0.0.1:8212
PALWORLD_API_USER=admin
PALWORLD_API_PASSWORD=mets-le-meme-mot-de-passe-que-AdminPassword-dans-PalWorldSettings.ini

# --- NSSM / service Windows ---
NSSM_PATH=C:\nssm\nssm.exe
SERVICE_NAME=PalworldServer

# --- Sauvegardes ---
SAVE_PATH=D:\PalworldServer\Server\Pal\Saved\SaveGames
BACKUP_DIR=D:\PalworldServer\Backups
BACKUP_KEEP_COUNT=14
BACKUP_CRON=0 4 * * *
# Alerte (Discord + journal d'activité) si l'espace disque libre sur BACKUP_DIR/SAVE_PATH
# descend sous ce seuil. Vérifié au démarrage puis toutes les 30 min.
DISK_SPACE_WARN_MB=2048

# --- Redémarrage planifié ---
# Ne sert plus que de valeur de départ : une fois le dashboard lancé, le planning (activation,
# heures, jours, délai d'avertissement) se configure depuis l'onglet "Réglages" du dashboard web.
RESTART_CRON=0 5 * * *
RESTART_WARNING_MINUTES=5

# --- Watchdog anti-crash ---
# Nombre de vérifications consécutives ratées avant redémarrage automatique
WATCHDOG_FAIL_THRESHOLD=3
# Intervalle entre deux vérifications (ms)
WATCHDOG_INTERVAL_MS=60000

# --- Mise à jour automatique (intégrée au bouton Redémarrer) ---
STEAMCMD_PATH=D:\PalworldServer\SteamCMD\steamcmd.exe
PALWORLD_INSTALL_DIR=D:\PalworldServer\Server

# --- Notifications Discord (optionnel) ---
# Configurable directement depuis le dashboard (Réglages > Notifications Discord), ou à la main :
# crée un webhook dans Discord (Paramètres du salon > Intégrations > Webhooks) et colle l'URL ici.
DISCORD_WEBHOOK_URL=
# Langue des messages envoyés à Discord ("fr" ou "en"). Indépendante de la langue du dashboard
# web (le webhook n'est pas lié à une session de navigateur) — gérée par le sélecteur du dashboard.
#DISCORD_LANG=fr
# Catégories de notifications (true par défaut ; mets "false" pour couper une catégorie).
# Gérées automatiquement par les cases à cocher du dashboard.
#DISCORD_NOTIFY_SERVER=true
#DISCORD_NOTIFY_PLAYERS=true
#DISCORD_NOTIFY_BACKUPS=true
#DISCORD_NOTIFY_UPDATES=true
#DISCORD_NOTIFY_ADMIN=true
#DISCORD_NOTIFY_DISK=true
#DISCORD_NOTIFY_RESTART=true
