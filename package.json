{
  "name": "palworld-dashboard",
  "version": "1.0.0",
  "description": "Dashboard web pour gérer un serveur Palworld dédié (start/stop/restart, sauvegardes, joueurs) + lanceur desktop d'installation",
  "author": "Vincent",
  "main": "electron/main.js",
  "scripts": {
    "start": "node server.js",
    "create-user": "node scripts/create-user.js",
    "mock": "node mock/mock-palworld-api.js",
    "test": "node --test",
    "electron:dev": "electron .",
    "fetch-node": "node scripts/fetch-node.js",
    "icon": "node scripts/generate-icon.js",
    "dist": "npm run icon && npm run fetch-node && electron-builder --win portable"
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "axios": "^1.7.9",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "express-session": "^1.18.1",
    "node-cron": "^4.5.0"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.palworld.dashboard.launcher",
    "productName": "PalworldDashboardLauncher",
    "asar": false,
    "files": [
      "electron/**/*",
      "lib/**/*",
      "public/**/*",
      "server.js",
      ".env.example",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "runtime",
        "to": "app/runtime"
      }
    ],
    "win": {
      "target": "portable",
      "icon": "build/icon.ico",
      "requestedExecutionLevel": "requireAdministrator"
    },
    "portable": {
      "artifactName": "PalworldDashboardLauncher.exe"
    }
  }
}
